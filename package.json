{
  "name": "vitest-express-mock",
  "version": "4.0.0",
  "description": "A lightweight Vitest mock for unit testing Express 5",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest --coverage",
    "test-verbose": "vitest --coverage --verbose",
    "test-watch": "vitest \"/*.ts\" --watchAll",
    "test-watch-all": "vitest --watchAll",
    "lint": "tsc --noEmit && eslint . --quiet --fix",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "prepublishOnly": "npm ci && npm run clean && npm run build",
    "release": "npm run prepublishOnly && npm run lint && npm run test",
    "ci": "npm run release --verbose"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skitscha/vitest-express-mock.git"
  },
  "keywords": [
    "test",
    "testing",
    "mock",
    "mocking",
    "vitest",
    "express",
    "expressjs",
    "controller",
    "ts",
    "typescript"
  ],
  "author": "skitscha",
  "contributors": [
    "bikk-uk (original @jest-mock/express author)",
    "eagleera (original vitest-mock-express fork)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/skitscha/vitest-express-mock/issues"
  },
  "homepage": "https://github.com/skitscha/vitest-express-mock#readme",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@types/express": "^5.0.0"
  }
}
